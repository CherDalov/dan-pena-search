# Copy this file to ".env" and fill in your Turso database credentials.
# Get both from https://app.turso.tech  (Database -> URL, and "Create Token").
# The real .env is gitignored - your token never gets committed.

TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
TURSO_AUTH_TOKEN=paste-your-auth-token-here
